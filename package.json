{
  "name": "jordanguyenwebsiteportfolio",
  "version": "1.0.0",
  "description": "Jordan's Portfolio \u2014 SDET Showcase",
  "main": "FirstPage.js",
  "type": "commonjs",
  "scripts": {
    "test": "cypress run --config baseUrl=https://d2kmkdebgfkxyh.cloudfront.net",
    "test:local": "cypress run",
    "test:open": "cypress open",
    "test:unit": "jest --passWithNoTests --testMatch='**/tests/unit/**/*.test.js'",
    "test:unit:watch": "jest --watch --testMatch='**/tests/unit/**/*.test.js'",
    "test:unit:coverage": "jest --coverage --passWithNoTests --testMatch='**/tests/unit/**/*.test.js'",
    "test:contract": "jest tests/contract/consumer.contact.test.js",
    "test:contract:verify": "jest tests/contract/provider.test.js",
    "test:perf": "lhci autorun --config=config/lighthouserc.js",
    "lint": "eslint \"assets/js/main.js\" \"cypress/**/*.js\" \"tests/unit/**/*.js\"",
    "lint:fix": "eslint --fix \"assets/js/**/*.js\" \"cypress/**/*.js\"",
    "prepare": "husky",
    "start": "http-server src",
    "test:playwright": "playwright test --config config/playwright.config.ts",
    "test:playwright:ui": "playwright test --config config/playwright.config.ts --ui",
    "test:playwright:report": "playwright show-report playwright-report --config config/playwright.config.ts",
    "test:visual": "cypress run --spec 'cypress/e2e/visual_regression.cy.js'",
    "test:mutation": "stryker run --config-file config/stryker.config.mjs",
    "test:security:deps": "snyk test --severity-threshold=high",
    "upload:images": "bash scripts/upload-images.sh",
    "test:playwright:update-snapshots": "playwright test --config config/playwright.config.ts --update-snapshots",
    "test:robot": "robot --variable BASE_URL:https://d2kmkdebgfkxyh.cloudfront.net --outputdir tests/robot/results --exclude api tests/robot/suites/",
    "test:robot:local": "robot --variable BASE_URL:http://localhost:8080 --outputdir tests/robot/results --exclude api tests/robot/suites/",
    "test:robot:smoke": "robot --variable BASE_URL:https://d2kmkdebgfkxyh.cloudfront.net --include smoke --outputdir tests/robot/results tests/robot/suites/",
    "test:robot:report": "python -m robot.rebot --outputdir tests/robot/results/combined tests/robot/results/*/output.xml",
    "test:robot:install": "pip install -r tests/robot/requirements.txt",
    "test:karate": "cd tests/karate && mvn test -Dtest=\"KarateRunner#runAll\" -q",
    "test:karate:health": "cd tests/karate && mvn test -Dtest=\"KarateRunner#runHealthChecks\" -q",
    "test:karate:contact": "cd tests/karate && mvn test -Dtest=\"KarateRunner#runContactApi\" -q",
    "test:karate:local": "cd tests/karate && mvn test -Dkarate.env=local -q",
    "test:karate:install": "cd tests/karate && mvn dependency:resolve -q"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/unit/**/*.test.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+github.com/JordanNguyen514/JordanNguyenWebsitePortfolio.git"
  },
  "keywords": [
    "sdet",
    "qa",
    "portfolio",
    "cypress",
    "playwright"
  ],
  "author": "Jordan Nguyen",
  "license": "ISC",
  "devDependencies": {
    "@applitools/eyes-cypress": "^3.58.13",
    "@lhci/cli": "^0.14.0",
    "@pact-foundation/pact": "^12.3.0",
    "@playwright/test": "^1.44.0",
    "@stryker-mutator/core": "^8.2.0",
    "@stryker-mutator/jest-runner": "^8.2.0",
    "cypress": "^15.13.1",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^3.5.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "snyk": "^1.1292.1"
  }
}